pipeline {
    agent any
    stages {
        stage('SSH to Remote Server') {
            steps {
                sshagent(['ssh-agent']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ec2-user@10.0.2.204 "
                        uptime &&
                        la -l
                        "
                    '''
                }
            }
        }
    }
}